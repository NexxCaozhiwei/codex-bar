<Window x:Class="CodexBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Bar"
        Width="260"
        Height="70"
        MinWidth="220"
        MinHeight="60"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="#364150"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10,7"
            MouseLeftButtonDown="OnMouseLeftButtonDown"
            MouseLeftButtonUp="OnMouseLeftButtonUp"
            MouseRightButtonUp="OnMouseRightButtonUp">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="18" />
                <RowDefinition Height="18" />
                <RowDefinition Height="18" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Codex" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{Binding RedLightBrush}" Margin="0,0,4,0" />
                    <Ellipse Width="8" Height="8" Fill="{Binding GreenLightBrush}" Margin="0,0,4,0" />
                    <Ellipse Width="8" Height="8" Fill="{Binding BlueLightBrush}" />
                </StackPanel>
                <TextBlock Grid.Column="4" Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontSize="12" VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="5h" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center" />
                <ProgressBar Grid.Column="1" Height="7" Minimum="0" Maximum="100" Value="{Binding FiveHourRemaining, Mode=OneWay}" Foreground="#2FBF71" Background="{StaticResource TrackBrush}" />
                <TextBlock Grid.Column="2" Text="{Binding FiveHourText}" Foreground="{StaticResource TextBrush}" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="7d" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center" />
                <ProgressBar Grid.Column="1" Height="7" Minimum="0" Maximum="100" Value="{Binding WeeklyRemaining, Mode=OneWay}" Foreground="#3DA5FF" Background="{StaticResource TrackBrush}" />
                <TextBlock Grid.Column="2" Text="{Binding WeeklyText}" Foreground="{StaticResource TextBrush}" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Border>
</Window>
