<Window x:Class="CodexBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Bar"
        Width="240"
        Height="86"
        MinWidth="230"
        MinHeight="78"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="Resources/CodexBar.ico"
        ShowActivated="True"
        ShowInTaskbar="False">
    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="#364150"
            BorderThickness="1"
            CornerRadius="6"
            Padding="9,7"
            MouseLeftButtonDown="OnMouseLeftButtonDown"
            MouseLeftButtonUp="OnMouseLeftButtonUp"
            MouseRightButtonUp="OnMouseRightButtonUp">
        <Grid VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="20" />
                <RowDefinition Height="20" />
                <RowDefinition Height="20" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Codex" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{Binding RedLightBrush}" Margin="0,0,4,0" />
                    <Ellipse Width="7" Height="7" Fill="{Binding GreenLightBrush}" Margin="0,0,4,0" />
                    <Ellipse Width="7" Height="7" Fill="{Binding BlueLightBrush}" />
                </StackPanel>
                <TextBlock Grid.Column="4" Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontSize="11" VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="62" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="5h" Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center" />
                <ProgressBar Grid.Column="1" Style="{StaticResource QuotaProgressBarStyle}" Minimum="0" Maximum="100" Value="{Binding FiveHourRemaining, Mode=OneWay}" Foreground="#2FBF71" Background="{StaticResource TrackBrush}" />
                <TextBlock Grid.Column="2" Text="{Binding FiveHourText}" Foreground="{StaticResource TextBrush}" FontSize="10" TextAlignment="Right" VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="62" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="7d" Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center" />
                <ProgressBar Grid.Column="1" Style="{StaticResource QuotaProgressBarStyle}" Minimum="0" Maximum="100" Value="{Binding WeeklyRemaining, Mode=OneWay}" Foreground="#3DA5FF" Background="{StaticResource TrackBrush}" />
                <TextBlock Grid.Column="2" Text="{Binding WeeklyText}" Foreground="{StaticResource TextBrush}" FontSize="10" TextAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Border>
</Window>
