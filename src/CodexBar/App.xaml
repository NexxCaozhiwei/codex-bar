<Application x:Class="CodexBar.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="OnStartup"
             Exit="OnExit"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#E61B1D24" />
        <SolidColorBrush x:Key="TextBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="MutedBrush" Color="#9DA7B3" />
        <SolidColorBrush x:Key="TrackBrush" Color="#333842" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2FBF71" />
        <Style x:Key="QuotaProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid ClipToBounds="True" SnapsToDevicePixels="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                            <Border x:Name="PART_Track" Background="Transparent" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
